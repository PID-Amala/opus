        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n  START[User sends any message to Opus WhatsApp Business]\n  START--&gt;|Decision: Is user already registered?|&gt;Y[Yes]\n  START--&gt;|Decision: Is user already registered?|&gt;N[No]\n  Y--&gt;|Go to|&gt;MAIN_MENU[Main Menu]\n  N--&gt;|Start|&gt;ONBOARDING[Onboarding]\n  ONBOARDING--&gt;|Collect First Name|&gt;COLLECT_FIRST_NAME[Collect First Name]\n  COLLECT_FIRST_NAME--&gt;|Collect Last Name|&gt;COLLECT_LAST_NAME[Collect Last Name]\n  COLLECT_LAST_NAME--&gt;|Collect Location (State/City)|&gt;COLLECT_LOCATION[Collect Location (State/City)]\n  COLLECT_LOCATION--&gt;|Ask user to choose verification method|&gt;CHOOSE_VERIFICATION_METHOD[Choose verification method]\n  CHOOSE_VERIFICATION_METHOD--&gt;|Collect verification number|&gt;COLLECT_VERIFICATION_NUMBER[Collect verification number]\n  COLLECT_VERIFICATION_NUMBER--&gt;|Send details to Verification Service|&gt;SEND_DETAILS_TO_VERIFICATION_SERVICE[Send details to Verification Service]\n  SEND_DETAILS_TO_VERIFICATION_SERVICE--&gt;|Decision: Verification successful?|&gt;YES[Yes]\n  SEND_DETAILS_TO_VERIFICATION_SERVICE--&gt;|Decision: Verification successful?|&gt;NO[No]\n  YES--&gt;|Create user account|&gt;CREATE_USER_ACCOUNT[Create user account]\n  YES--&gt;|Mark user as Verified|&gt;MARK_USER_VERIFIED[Mark user as Verified]\n  YES--&gt;|Send \&quot;Verification successful. You can now use Opus.\&quot;|&gt;SEND_VERIFICATION_SUCCESSFUL[Send \&quot;Verification successful. You can now use Opus.\&quot;]\n  YES--&gt;|Go to|&gt;MAIN_MENU[Main Menu]\n  NO--&gt;|Send \&quot;Verification failed.\&quot;|&gt;SEND_VERIFICATION_FAILED[Send \&quot;Verification failed.\&quot;]\n  NO--&gt;|Ask user to: Retry verification|&gt;ASK_USER_TO_RETRY_VERIFICATION[Ask user to: Retry verification]\n  ASK_USER_TO_RETRY_VERIFICATION--&gt;|Choose another verification method|&gt;CHOOSE_ANOTHER_VERIFICATION_METHOD[Choose another verification method]\n  CHOOSE_ANOTHER_VERIFICATION_METHOD--&gt;|Cancel onboarding|&gt;CANCEL_ONBOARDING[Cancel onboarding]\n  MAIN_MENU--&gt;|Start Escrow Transaction|&gt;START_ESCROW_TRANSACTION[Start Escrow Transaction]\n  START_ESCROW_TRANSACTION--&gt;|Ask: Item/Service description|&gt;ASK_ITEM_SERVICE_DESCRIPTION[Ask: Item/Service description]\n  ASK_ITEM_SERVICE_DESCRIPTION--&gt;|Ask: Amount|&gt;ASK_AMOUNT[Ask: Amount]\n  ASK_AMOUNT--&gt;|Ask: Counterparty phone number|&gt;ASK_COUNTERPARTY_PHONE_NUMBER[Ask: Counterparty phone number]\n  ASK_COUNTERPARTY_PHONE_NUMBER--&gt;|Ask: Who is paying?|&gt;ASK_WHO_IS_PAYING[Ask: Who is paying?]\n  ASK_WHO_IS_PAYING--&gt;|Ask: Who is receiving?|&gt;ASK_WHO_IS_RECEIVING[Ask: Who is receiving?]\n  ASK_WHO_IS_RECEIVING--&gt;|Create Transaction|&gt;CREATE_TRANSACTION[Create Transaction]\n  CREATE_TRANSACTION--&gt;|Status = pending_acceptance|&gt;STATUS_PENDING_ACCEPTANCE[Status = pending_acceptance]\n  STATUS_PENDING_ACCEPTANCE--&gt;|Send invitation to counterparty|&gt;SEND_INVITATION_TO_COUNTERPARTY[Send invitation to counterparty]\n  SEND_INVITATION_TO_COUNTERPARTY--&gt;|Decision: Counterparty accepts?|&gt;YES_ACCEPTANCE[Yes]\n  SEND_INVITATION_TO_COUNTERPARTY--&gt;|Decision: Counterparty accepts?|&gt;NO_ACCEPTANCE[No]\n  YES_ACCEPTANCE--&gt;|Status = awaiting_payment|&gt;STATUS_AWAITING_PAYMENT[Status = awaiting_payment]\n  NO_ACCEPTANCE--&gt;|Status = cancelled|&gt;STATUS_CANCELLED[Status = cancelled]\n  STATUS_CANCELLED--&gt;|Notify both parties|&gt;NOTIFY_BOTH_PARTIES[Notify both parties]\n  STATUS_CANCELLED--&gt;|End|&gt;END[End]\n  STATUS_AWAITING_PAYMENT--&gt;|Generate: Unique Virtual Account OR Payment Link|&gt;GENERATE_VIRTUAL_ACCOUNT_OR_PAYMENT_LINK[Generate: Unique Virtual Account OR Payment Link]\n  GENERATE_VIRTUAL_ACCOUNT_OR_PAYMENT_LINK--&gt;|Buyer pays|&gt;BUYER_PAYS[Buyer pays]\n  BUYER_PAYS--&gt;|Receive Nomba webhook|&gt;RECEIVE_NOMBA_WEBHOOK[Receive Nomba webhook]\n  RECEIVE_NOMBA_WEBHOOK--&gt;|Decision: Payment received?|&gt;YES_PAYMENT_RECEIVED[Yes]\n  RECEIVE_NOMBA_WEBHOOK--&gt;|Decision: Payment received?|&gt;NO_PAYMENT_RECEIVED[No]\n  YES_PAYMENT_RECEIVED--&gt;|Status = funds_held|&gt;STATUS_FUNDS_HELD[Status = funds_held]\n  YES_PAYMENT_RECEIVED--&gt;|Notify buyer: \&quot;Payment received and held securely.\&quot;|&gt;NOTIFY_BUYER_PAYMENT_RECEIVED[Notify buyer: \&quot;Payment received and held securely.\&quot;]\n  YES_PAYMENT_RECEIVED--&gt;|Notify seller: \&quot;Buyer has paid. Please deliver the item.\&quot;|&gt;NOTIFY_SELLER_PAYMENT_RECEIVED[Notify seller: \&quot;Buyer has paid. Please deliver the item.\&quot;]\n  NO_PAYMENT_RECEIVED--&gt;|Wait until payment timeout|&gt;WAIT_UNTIL_PAYMENT_TIMEOUT[Wait until payment timeout]\n  WAIT_UNTIL_PAYMENT_TIMEOUT--&gt;|If timeout expires: Status = expired|&gt;STATUS_EXPIRED[Status = expired]\n  STATUS_EXPIRED--&gt;|Notify both parties|&gt;NOTIFY_BOTH_PARTIES[Notify both parties]\n  STATUS_EXPIRED--&gt;|End|&gt;END[End]\n  STATUS_FUNDS_HELD--&gt;|Seller delivers item/service|&gt;SELLER_DELIVERS_ITEM_SERVICE[Seller delivers item/service]\n  SELLER_DELIVERS_ITEM_SERVICE--&gt;|Seller optionally sends \&quot;Delivered\&quot;|&gt;SELLER_OPTIONALLY SENDS_DELIVERED[Seller optionally sends \&quot;Delivered\&quot;]\n  SELLER_DELIVERS_ITEM_SERVICE--&gt;|Buyer receives confirmation request|&gt;BUYER_RECEIVES_CONFIRMATION_REQUEST[Buyer receives confirmation request]\n  BUYER_RECEIVES_CONFIRMATION_REQUEST--&gt;|Decision: Buyer confirms?|&gt;YES_BUYER_CONFIRMED[Yes]\n  BUYER_RECEIVES_CONFIRMATION_REQUEST--&gt;|Decision: Buyer confirms?|&gt;NO_BUYER_CONFIRMED[No]\n  YES_BUYER_CONFIRMED--&gt;|Status = release_approved|&gt;STATUS_RELEASE_APPROVED[Status = release_approved]\n  NO_BUYER_CONFIRMED--&gt;|Status = disputed|&gt;STATUS_DISPUTED[Status = disputed]\n  NO_BUYER_CONFIRMED--&gt;|No response after X days|&gt;NO_RESPONSE_AFTER_X_DAYS[No response after X days]\n  NO_RESPONSE_AFTER_X_DAYS--&gt;|Auto Release? OR Auto Dispute?|&gt;AUTO_RELEASE_OR_AUTO_DISPUTE[Auto Release? OR Auto Dispute?]\n  AUTO_RELEASE_OR_AUTO_DISPUTE--&gt;|Call Nomba Transfer API|&gt;CALL_NOMBA_TRANSFER_API[Call Nomba Transfer API]\n  CALL_NOMBA_TRANSFER_API--&gt;|Transfer funds to seller|&gt;TRANSFER_FUNDS_TO_SELLER[Transfer funds to seller]\n  TRANSFER_FUNDS_TO_SELLER--&gt;|Deduct Opus fee|&gt;DEDUCT_OPUS_FEE[Deduct Opus fee]\n  DEDUCT_OPUS_FEE--&gt;|Status = completed|&gt;STATUS_COMPLETED[Status = completed]\n  STATUS_COMPLETED--&gt;|Notify buyer and seller|&gt;NOTIFY_BUYER_AND_SELLER[Notify buyer and seller]\n  STATUS_COMPLETED--&gt;|End|&gt;END[End]\n  STATUS_DISPUTED--&gt;|Freeze funds|&gt;FREEZE_FUNDS[Freeze funds]\n  FREEZE_FUNDS--&gt;|Notify both parties|&gt;NOTIFY_BOTH_PARTIES[Notify both parties]\n  FREEZE_FUNDS--&gt;|Human administrator reviews|&gt;HUMAN_ADMINISTRATOR_REVIEWS[Human administrator reviews]\n  HUMAN_ADMINISTRATOR_REVIEWS--&gt;|Decision: Release to Seller|&gt;RELEASE_TO_SELLER[Release to Seller]\n  HUMAN_ADMINISTRATOR_REVIEWS--&gt;|Decision: Release to Seller|&gt;REFUND_BUYER[Refund Buyer]\n  RELEASE_TO_SELLER--&gt;|Call payout API|&gt;CALL_PAYOUT_API[Call payout API]\n  RELEASE_TO_SELLER--&gt;|Status = completed|&gt;STATUS_COMPLETED[Status = completed]\n  REFUND_BUYER--&gt;|Call refund API|&gt;CALL_REFUND_API[Call refund API]\n  REFUND_BUYER--&gt;|Status = refunded|&gt;STATUS_REFUNDED[Status = refunded]\n  REFUND_BUYER--&gt;|Notify both parties|&gt;NOTIFY_BOTH_PARTIES[Notify both parties]\n  REFUND_BUYER--&gt;|End|&gt;END[End]&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="W0jGzeyPghXnBsJHMu_o-0">
